	"tokenColors": [
		{
			"scope": [
				"comment",
				"punctuation.definition.comment"
			],
			"settings": {
				"foreground": "#7a9485",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"string",
				"markup.inline.raw",
				"string.tag"
			],
			"settings": {
				"foreground": "#b06030"
			}
		},
		{
			"scope": [
				"constant.numeric",
				"constant.language",
				"constant.character",
				"constant.other"
			],
			"settings": {
				"foreground": "#9a7020"
			}
		},
		{
			"scope": [
				"keyword",
				"storage",
				"storage.type",
				"storage.modifier"
			],
			"settings": {
				"foreground": "#2e7a46"
			}
		},
		{
			"scope": [
				"keyword.operator",
				"punctuation.separator",
				"punctuation.accessor"
			],
			"settings": {
				"foreground": "#5f8a6d"
			}
		},
		{
			"scope": [
				"entity.name.function",
				"support.function",
				"meta.function-call",
				"variable.function"
			],
			"settings": {
				"foreground": "#a07820"
			}
		},
		{
			"scope": [
				"entity.name.type",
				"entity.name.class",
				"entity.name.namespace",
				"support.type",
				"support.class"
			],
			"settings": {
				"foreground": "#9a6835"
			}
		},
		{
			"scope": [
				"variable",
				"meta.definition.variable.name",
				"entity.name.variable"
			],
			"settings": {
				"foreground": "#1f8a96"
			}
		},
		{
			"scope": [
				"variable.language",
				"variable.parameter",
				"meta.parameter"
			],
			"settings": {
				"foreground": "#7a50a0"
			}
		},
		{
			"scope": [
				"variable.other.constant",
				"variable.other.enummember"
			],
			"settings": {
				"foreground": "#5a7a20"
			}
		},
		{
			"scope": [
				"entity.other.attribute-name",
				"support.type.property-name",
				"meta.object-literal.key"
			],
			"settings": {
				"foreground": "#c06030"
			}
		},
		{
			"scope": [
				"support.type.property-name.json",
				"support.type.property-name.jsonc"
			],
			"settings": {
				"foreground": "#1878a0"
			}
		},
		{
			"scope": [
				"entity.name.tag",
				"punctuation.definition.tag"
			],
			"settings": {
				"foreground": "#2e7a46"
			}
		},
		{
			"scope": [
				"markup.heading",
				"markup.bold"
			],
			"settings": {
				"foreground": "#a07820",
				"fontStyle": "bold"
			}
		},
		{
			"scope": [
				"markup.italic",
				"emphasis"
			],
			"settings": {
				"foreground": "#9a7020",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"markup.inserted",
				"markup.deleted",
				"markup.changed"
			],
			"settings": {
				"foreground": "#c86e43"
			}
		},
		{
			"scope": [
				"invalid",
				"invalid.illegal"
			],
			"settings": {
				"foreground": "#8b1a08"
			}
		},
		{
			"scope": [
				"regexp",
				"string.regexp"
			],
			"settings": {
				"foreground": "#5e8c18"
			}
		},
		{
			"scope": [
				"punctuation.section.embedded.begin",
				"punctuation.section.embedded.end"
			],
			"settings": {
				"foreground": "#2e7a46"
			}
		},
		{
			"scope": [
				"support.other.namespace",
				"meta.use",
				"entity.name.type.namespace",
				"storage.type.namespace"
			],
			"settings": {
				"foreground": "#9a6835"
			}
		}
	],
	"semanticTokenColors": {
		"namespace": "#9a6835",
		"class": "#9a6835",
		"enum": "#9a6835",
		"interface": "#b07840",
		"typeParameter": "#a88858",
		"type": "#9a6835",
		"parameter": "#7a50a0",
		"variable": "#1f8a96",
		"property": "#c06030",
		"property:json": "#1878a0",
		"property:jsonc": "#1878a0",
		"enumMember": "#5a7a20",
		"function": "#a07820",
		"method": "#a07820",
		"macro": "#c86e43",
		"keyword": "#2e7a46",
		"string": "#b06030",
		"number": "#9a7020",
		"regexp": "#5e8c18",
		"operator": "#5f8a6d",
		"comment": {
			"foreground": "#7a9485",
			"fontStyle": "italic"
		}
	}
}