	"tokenColors": [
		{
			"scope": [
				"comment",
				"punctuation.definition.comment"
			],
			"settings": {
				"foreground": "#6b8d72",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"string",
				"markup.inline.raw",
				"string.tag"
			],
			"settings": {
				"foreground": "#e39a67"
			}
		},
		{
			"scope": [
				"constant.numeric",
				"constant.language",
				"constant.character",
				"constant.other"
			],
			"settings": {
				"foreground": "#dcb170"
			}
		},
		{
			"scope": [
				"keyword",
				"storage",
				"storage.type",
				"storage.modifier"
			],
			"settings": {
				"foreground": "#4fa15a"
			}
		},
		{
			"scope": [
				"keyword.operator",
				"punctuation.separator",
				"punctuation.accessor"
			],
			"settings": {
				"foreground": "#86b07f"
			}
		},
		{
			"scope": [
				"entity.name.function",
				"support.function",
				"meta.function-call",
				"variable.function"
			],
			"settings": {
				"foreground": "#c9a028"
			}
		},
		{
			"scope": [
				"entity.name.type",
				"entity.name.class",
				"entity.name.namespace",
				"support.type",
				"support.class"
			],
			"settings": {
				"foreground": "#c4905c"
			}
		},
		{
			"scope": [
				"variable",
				"meta.definition.variable.name",
				"entity.name.variable"
			],
			"settings": {
				"foreground": "#8adde8"
			}
		},
		{
			"scope": [
				"variable.language",
				"variable.parameter",
				"meta.parameter"
			],
			"settings": {
				"foreground": "#c8a5e0"
			}
		},
		{
			"scope": [
				"variable.other.constant",
				"variable.other.enummember"
			],
			"settings": {
				"foreground": "#d0e89a"
			}
		},
		{
			"scope": [
				"entity.other.attribute-name",
				"support.type.property-name",
				"meta.object-literal.key"
			],
			"settings": {
				"foreground": "#ec8f65"
			}
		},
		{
			"scope": [
				"support.type.property-name.json",
				"support.type.property-name.jsonc"
			],
			"settings": {
				"foreground": "#7ecfdc"
			}
		},
		{
			"scope": [
				"entity.name.tag",
				"punctuation.definition.tag"
			],
			"settings": {
				"foreground": "#5aab5f"
			}
		},
		{
			"scope": [
				"markup.heading",
				"markup.bold"
			],
			"settings": {
				"foreground": "#c9a028",
				"fontStyle": "bold"
			}
		},
		{
			"scope": [
				"markup.italic",
				"emphasis"
			],
			"settings": {
				"foreground": "#dcb170",
				"fontStyle": "italic"
			}
		},
		{
			"scope": [
				"markup.inserted",
				"markup.deleted",
				"markup.changed"
			],
			"settings": {
				"foreground": "#e57e61"
			}
		},
		{
			"scope": [
				"invalid",
				"invalid.illegal"
			],
			"settings": {
				"foreground": "#f7e9e4"
			}
		},
		{
			"scope": [
				"regexp",
				"string.regexp"
			],
			"settings": {
				"foreground": "#b8df71"
			}		},
		{
			"scope": [
				"punctuation.section.embedded.begin",
				"punctuation.section.embedded.end"
			],
			"settings": {
				"foreground": "#4fa15a"
			}
		},
		{
			"scope": [
				"support.other.namespace",
				"meta.use",
				"entity.name.type.namespace",
				"storage.type.namespace"
			],
			"settings": {
				"foreground": "#c4905c"
			}		},
	],
	"semanticTokenColors": {
		"namespace": "#c4905c",
		"class": "#c4905c",
		"enum": "#c4905c",
		"interface": "#d4a470",
		"typeParameter": "#c9a87e",
		"type": "#c4905c",
		"parameter": "#c8a5e0",
		"variable": "#8adde8",
		"property": "#ec8f65",
		"property:json": "#7ecfdc",
		"property:jsonc": "#7ecfdc",
		"enumMember": "#d0e89a",
		"function": "#c9a028",
		"method": "#c9a028",
		"macro": "#df8c59",
		"keyword": "#4fa15a",
		"string": "#e39a67",
		"number": "#dcb170",
		"regexp": "#b8df71",
		"operator": "#86b07f",
		"comment": {
			"foreground": "#6b8d72",
			"fontStyle": "italic"
		}
	}
}